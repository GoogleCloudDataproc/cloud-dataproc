source lib/env.sh

if [[ -z "$1" ]]; then
  echo "$0 [-m node index] <local_path>"
  exit 1
fi

# If the first argument is a number, assume it indicates which m node to send file to
M_HOSTNAME="${CLUSTER_NAME}-m"
if [[ $(perl -e "print 1 if q{$1} =~ /^\d+$/") == "1" ]]; then
  m_num="$1"
  echo "m_num: $m_num"
  M_HOSTNAME="${M_HOSTNAME}-${m_num}"
  shift 1
else
  M_HOSTNAME="${M_HOSTNAME}"
fi

date

gcloud compute scp --recurse "$*" \
  --zone ${ZONE} \
  ${M_HOSTNAME}:/tmp  \
  --tunnel-through-iap \
  --project ${PROJECT_ID}
