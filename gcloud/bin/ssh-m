source lib/env.sh

M_HOSTNAME="${CLUSTER_NAME}-m"
# If the first argument is a number, treat it as the master index for HA
if [[ "$1" =~ ^[0-9]+$ ]]; then
  M_HOSTNAME="${M_HOSTNAME}-${1}"
  shift # Remove the index from the arguments
fi

# The rest of the arguments are the command to be executed
COMMAND_TO_RUN="$@"

gcloud compute ssh --zone "${ZONE}" "${M_HOSTNAME}" --tunnel-through-iap --project "${PROJECT_ID}" -- -t -o ConnectTimeout=360 -AY ${COMMAND_TO_RUN}
